<Window x:Class="Konyvtar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Konyvtar"
        mc:Ignorable="d"
        Title="Menhely" Height="460" Width="800" ResizeMode="NoResize" Loaded="Window_Loaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="250" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBox Grid.Row="0" Grid.ColumnSpan="2"
             Margin="10"
             Height="25"
             Name="search"
                 />

        <DataGrid Name="adatLista" Grid.Row="1" Grid.Column="0"
              Margin="10"
              SelectionChanged="adatLista_SelectionChanged"
              />

        <StackPanel Grid.Row="1" Grid.Column="1" Margin="10">

            <Label Content="Név:" Margin="0,0,190,0"/>
            <TextBox Name="nev" Margin="0,-20,0,0" Width="150" TextChanged="nev_TextChanged"/>

            <Label Content="Faj:" Margin="0,10,190,0"/>
            <ComboBox Name="faj" Margin="0,-20,0,0" Width="150" SelectionChanged="faj_SelectionChanged"/>

            <Label Content="Nem:" Margin="0,10,190,0"/>
            <StackPanel Orientation="Horizontal" Margin="0,-20,0,0" Width="150">
                <RadioButton Name="himRadio" Content="Hím" GroupName="nem" Margin="10,0,0,0" Checked="RadioButtonChecked"/>
                <RadioButton Name="nostenyRadio" Content="Nőstény" GroupName="nem" Margin="20,0,0,0" Checked="RadioButtonChecked"/>
            </StackPanel>

            <Label Content="Behozatala:" Margin="0,10,160,0"/>
            <DatePicker Name="behozatal" Width="150" Margin="65,-20,0,0" SelectedDateChanged="behozatal_SelectedDateChanged"/>

            <Button Name="hozzaadas" Content="Hozzáadás" Margin="0,20,0,0" IsEnabled="False" Click="hozzaadas_Click"/>
            <Button Name="torles" Content="Törlés" Margin="0,150,0,0" IsEnabled="False" Click="torles_Click"/>

        </StackPanel>
    </Grid>
</Window>
